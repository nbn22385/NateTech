---
import { Sun, Moon } from 'lucide-react';

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/contact', label: 'Contact' },
  { href: '/book', label: 'Book' },
];
---

<header class="navbar bg-base-200 sticky top-0 z-50 shadow-sm">
  <div class="flex-1">
    <a href="/" class="text-xl font-bold text-primary">NateTech Solutions</a>
  </div>
  <div class="flex-none">
    <ul class="menu menu-horizontal px-1 hidden md:flex gap-1">
      {navLinks.map(link => (
        <li><a href={link.href}>{link.label}</a></li>
      ))}
      <li>
        <label class="swap swap-rotate btn btn-ghost btn-circle btn-sm">
          <input type="checkbox" id="theme-toggle" />
          <Sun className="swap-on w-5 h-5" />
          <Moon className="swap-off w-5 h-5" />
        </label>
      </li>
    </ul>
    <div class="dropdown dropdown-end md:hidden">
      <div tabindex="0" role="button" class="btn btn-ghost btn-circle">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7" />
        </svg>
      </div>
      <ul tabindex="0" class="menu menu-sm dropdown-content mt-3 z-[1] p-2 shadow bg-base-100 rounded-box w-52">
        {navLinks.map(link => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
        <li>
          <label class="swap swap-rotate">
            <input type="checkbox" id="theme-toggle-mobile" />
            <Sun className="swap-on w-5 h-5" />
            <Moon className="swap-off w-5 h-5" />
          </label>
        </li>
      </ul>
    </div>
  </div>
</header>
