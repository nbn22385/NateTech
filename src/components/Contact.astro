---
---

<section id="contact" class="py-16 bg-base-100">
  <div class="container mx-auto px-4">
    <h2 class="text-3xl font-bold text-center mb-12">Contact Us</h2>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 max-w-5xl mx-auto">
      <div class="card bg-base-200 shadow-md">
        <div class="card-body">
          <h3 class="card-title mb-4">Send us a Message</h3>
          <p class="text-sm opacity-70 mb-4">Fill out the form below and we'll get back to you as soon as possible.</p>
          <div class="bg-base-100 rounded-lg p-2 min-h-[500px]">
            <iframe 
              src="https://docs.google.com/forms/d/e/1FAIpQLSezyQjhsHQX5tthXG05Kh0Q5XzMkU8c8vjZawCB79NYO12Ilw/viewform?embedded=true" 
              width="100%" 
              height="700" 
              frameborder="0" 
              marginheight="0" 
              marginwidth="0">
              Loading…
            </iframe>
          </div>
          <div class="divider">OR</div>
          <div class="text-center space-y-2">
            <p class="font-semibold">Direct Contact</p>
            <p>📞 (555) 123-4567</p>
            <p>✉️ nate@natetech.example.com</p>
          </div>
        </div>
      </div>
      
      <div class="card bg-base-200 shadow-md">
        <div class="card-body">
          <h3 class="card-title mb-4">Book an Appointment</h3>
          <p class="text-sm opacity-70 mb-4">Schedule a time that works for you. Select an available slot to book your appointment.</p>
          <div class="bg-base-100 rounded-lg p-2 min-h-[500px]">
            <!-- Google Calendar Embed - Replace src with your actual embed code -->
            <iframe 
              src="https://calendar.google.com/calendar/embed?src=YOUR_CALENDAR_LINK&ctz=America/New_York" 
              style="border: 0; width: 100%; height: 500px;" 
              frameborder="0" 
              scrolling="no">
            </iframe>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
