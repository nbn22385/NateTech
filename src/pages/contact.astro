---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contact - NateTech Solutions">
  <Header />
  <main class="container mx-auto px-4 py-16">
    <h1 class="text-4xl font-bold text-center mb-12">Contact Us</h1>
    <div class="max-w-3xl mx-auto">
      <div class="card bg-base-200 shadow-md">
        <div class="card-body">
          <h2 class="card-title mb-4">Send us a Message</h2>
          <p class="text-sm opacity-70 mb-4">Fill out the form below and we'll get back to you as soon as possible.</p>
          <div class="bg-base-100 rounded-lg p-2 min-h-[500px]">
            <iframe 
              src="https://docs.google.com/forms/d/e/1FAIpQLSezyQjhsHQX5tthXG05Kh0Q5XzMkU8c8vjZawCB79NYO12Ilw/viewform?embedded=true" 
              width="100%" 
              height="700" 
              frameborder="0" 
              marginheight="0" 
              marginwidth="0">
              Loading…
            </iframe>
          </div>
          <div class="divider">OR</div>
          <div class="text-center space-y-2">
            <p class="font-semibold">Direct Contact</p>
            <p>📞 (555) 123-4567</p>
            <p>✉️ nate@natetech.example.com</p>
          </div>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
