---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Book Appointment - NateTech Solutions">
  <Header />
  <main class="container mx-auto px-4 py-16">
    <h1 class="text-4xl font-bold text-center mb-12">Book an Appointment</h1>
    <div class="max-w-3xl mx-auto">
      <div class="card bg-base-200 shadow-md">
        <div class="card-body">
          <p class="text-sm opacity-70 mb-4">Schedule a time that works for you. Select an available slot to book your appointment.</p>
          <div class="bg-base-100 rounded-lg p-2 min-h-[600px]">
            <iframe 
              src="https://calendar.google.com/calendar/appointments/schedules/AcZssZ0Q2o0Gx6DIkMP7yZdB7_OR-G0ejWbx75gMWqfFx52dp-UuyvstBCPx-K2Q1DQ30Ri8TgHF1z_N?gv=true" 
              style="border: 0; width: 100%; height: 600px;" 
              frameborder="0">
            </iframe>
          </div>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
